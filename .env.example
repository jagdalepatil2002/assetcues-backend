# ================================================================
# LOGGING (terminal / Uvicorn stderr)
# ================================================================
# LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG

# ================================================================
# MODEL CONFIGURATION — ALL GEMINI FOR V1
# Change provider + model + key to swap. Zero code changes.
# Primary can be gemini-2.0-flash (legacy; Google may 404 for brand-new keys). Cheap/verify: 2.5-flash-lite.
# ================================================================

PRIMARY_VLM_PROVIDER=google
PRIMARY_VLM_MODEL=gemini-2.0-flash
PRIMARY_VLM_BASE_URL=

VERIFICATION_VLM_PROVIDER=google
VERIFICATION_VLM_MODEL=gemini-2.5-flash-lite
VERIFICATION_VLM_BASE_URL=

CHEAP_VLM_PROVIDER=google
CHEAP_VLM_MODEL=gemini-2.5-flash-lite
CHEAP_VLM_BASE_URL=

GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=

PRIMARY_THINKING_LEVEL_SIMPLE=low
PRIMARY_THINKING_LEVEL_COMPLEX=high

# ================================================================
# THRESHOLDS
# ================================================================
CONFIDENCE_AUTO_ACCEPT=0.90
CONFIDENCE_REREAD_THRESHOLD=0.80
CONFIDENCE_VERIFICATION_MIN=0.50
CONFIDENCE_VERIFICATION_MAX=0.90
RESEARCH_SPLIT_MIN_VALUE=100000
QUALITY_THRESHOLD_ENHANCE=0.4
QUALITY_THRESHOLD_HANDWRITING=0.6

# ================================================================
# API SETTINGS
# ================================================================
MAX_FILE_SIZE_MB=50
API_TIMEOUT_SECONDS=120
VLM_CONCURRENCY_LIMIT=5
MAX_RETRY_LOOPS=2

# Large PDFs (1–100+ pages): reject above cap; batch VLM calls; lower DPI when many pages
MAX_PDF_PAGES=100
VLM_MAX_PAGES_PER_REQUEST=8
PDF_RENDER_DPI_DEFAULT=300
PDF_RENDER_DPI_REDUCED=200
PDF_LARGE_PAGE_THRESHOLD=12

# ================================================================
# TRAINING DATA (toggleable)
# ================================================================
SAVE_TRAINING_DATA=false
TRAINING_DATA_DIR=./training_data
